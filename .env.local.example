# Supabase - copie para .env.local e preencha com os valores do seu projeto
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Necessário para convite de usuários (painel Admin). Nunca expor no client.
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# URL pública da aplicação — usada nos links de email (convites, reset de senha)
# Local:    http://localhost:3000
# Vercel:   defina no painel Vercel > Settings > Environment Variables com o domínio real
#           Ex: https://seu-app.vercel.app ou https://seudominio.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
